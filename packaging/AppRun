#!/bin/bash
# AppImage entry point for Local AI Hub.
# Locates the bundle dir, makes the bundled system libs (NSS, etc.) findable,
# points Qt at the bundled plugins + WebEngine runtime, and launches the app.
HERE="$(dirname "$(readlink -f "${0}")")"
INTERNAL="${HERE}/usr/bin/_internal"
QTROOT="${INTERNAL}/PySide6/Qt"

export LD_LIBRARY_PATH="${HERE}/usr/lib:${QTROOT}/lib:${INTERNAL}:${LD_LIBRARY_PATH}"

# Qt plugin + WebEngine paths (qt.conf next to the exe also declares these; setting
# them here too makes the bundle robust regardless of how Qt resolves its prefix).
export QT_PLUGIN_PATH="${QTROOT}/plugins"
export QT_QPA_PLATFORM_PLUGIN_PATH="${QTROOT}/plugins/platforms"
export QTWEBENGINEPROCESS_PATH="${QTROOT}/libexec/QtWebEngineProcess"

# QtWebEngine on an unknown machine: force software GL (no assumptions about the
# GPU / drivers) and disable the Chromium sandbox, which needs a setuid helper or
# user namespaces a portable bundle can't rely on. The content is local, so this
# is the standard, safe choice for a bundled WebEngine app.
export QTWEBENGINE_CHROMIUM_FLAGS="--disable-gpu --no-sandbox ${QTWEBENGINE_CHROMIUM_FLAGS:-}"

exec "${HERE}/usr/bin/local-ai-hub" "$@"
